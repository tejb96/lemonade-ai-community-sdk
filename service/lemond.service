[Unit]
Description=Lemonade Local LLM Server
Documentation=https://lemonade-server.ai/docs/
After=network.target

[Service]
Environment=HOME=/home/workshop
Environment=HF_HOME=/home/workshop/.cache/huggingface
Environment=HF_HUB_CACHE=/home/workshop/.cache/huggingface/hub
Environment=LEMONADE_CACHE_DIR=/home/workshop/.cache/lemonade
ExecStart=/bin/bash -lc "lemond /home/workshop/.cache/lemonade"
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
