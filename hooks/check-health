#!/bin/bash
# check-health: invoked by Workshop after launch/refresh to determine whether
# the SDK is fully operational. Must call 'workshopctl set-health' exactly once.
#
# Health states:
#   okay    — lemond is running and responding on /api/v1/health
#   waiting — lemond is starting up; Workshop retries every second (up to 10x)
#             before auto-promoting to 'error'.
#
# Phase 2: this hook is intentionally single-shot. The previous 30 s in-hook
# polling loop duplicated Workshop's own retry semantics and made failure modes
# harder to read. We let Workshop retry 'waiting' and promote to 'error' itself.
set -euo pipefail

PORT=13305
HEALTH_URL="http://127.0.0.1:${PORT}/api/v1/health"

if ! sudo -u workshop --login systemctl --user is-active --quiet lemond; then
    workshopctl set-health waiting "lemond service is not yet active"
    exit 0
fi

if sudo -u workshop --login curl -sf --max-time 3 "${HEALTH_URL}" >/dev/null 2>&1; then
    workshopctl set-health okay
    exit 0
fi

workshopctl set-health waiting "lemond not yet responding on :${PORT}/api/v1/health"
