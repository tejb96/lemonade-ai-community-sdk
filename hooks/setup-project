#!/bin/bash
# setup-project: runs as the 'workshop' user after interfaces are connected.
# Called on each workshop launch and refresh.
#
# At this point:
#   - The model-cache mount is live (/home/workshop/.cache/lemonade is writable).
#   - The huggingface-cache mount is live (/home/workshop/.cache/huggingface is writable).
#   - $SDK points to the SDK's installed files (lemond + lemonade in $SDK/bin).
#
# Phase 2: hardware detection has moved out of this hook — lemond now probes
# available backends on startup itself, so we only write a minimal config.json
# (preserving any pre-existing user customisations) and install / start the
# systemd user unit.
set -euo pipefail

LEMONADE_CACHE="${HOME}/.cache/lemonade"
HF_CACHE="${HOME}/.cache/huggingface"
CONFIG_FILE="${LEMONADE_CACHE}/config.json"
SERVICE_DIR="${HOME}/.config/systemd/user"

mkdir -p "${LEMONADE_CACHE}" "${HF_CACHE}/hub" "${SERVICE_DIR}"

if [ ! -f "${CONFIG_FILE}" ]; then
    echo "[lemonade-sdk] Writing default config.json..."
    cat > "${CONFIG_FILE}" <<EOF
{
  "config_version": 1,
  "port": 13305,
  "host": "localhost",
  "log_level": "info",
  "no_broadcast": true,
  "models_dir": "auto",
  "ctx_size": 4096,
  "llamacpp": { "backend": "auto" }
}
EOF
fi

install -D --mode=644 "${SDK}/lemond.service" "${SERVICE_DIR}/lemond.service"
systemctl --user daemon-reload
systemctl --user enable --now lemond

echo "[lemonade-sdk] setup-project complete. Lemonade listening on :13305"
